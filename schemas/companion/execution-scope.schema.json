{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Scope v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "work_item_id",
    "status",
    "project_root",
    "git_head",
    "allowed_paths",
    "forbidden_domains",
    "generated_at_utc"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "work_item_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "unresolved",
        "exact",
        "blocked"
      ]
    },
    "project_root": {
      "type": "string",
      "minLength": 1
    },
    "git_head": {
      "type": [
        "string",
        "null"
      ]
    },
    "allowed_paths": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "forbidden_domains": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "external_drift": {
      "type": "boolean"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
