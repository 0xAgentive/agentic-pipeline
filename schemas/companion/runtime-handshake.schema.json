{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Runtime Handshake v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_utc",
    "pipeline_package_version",
    "runtime_version",
    "project_root",
    "workspace_root",
    "git_root",
    "git_head",
    "state_root",
    "artifact_root",
    "command_inventory_path",
    "command_inventory_sha256",
    "available_commands",
    "current_phase",
    "current_status",
    "next_required_command",
    "commands_allowed_now",
    "routing_valid",
    "routing_errors",
    "git_state",
    "routing_mode",
    "inventory_source",
    "inventory_trust",
    "inventory_path",
    "inventory_sha256",
    "inventory_command_count",
    "installation_manifest_path",
    "installation_manifest_sha256",
    "installed_project_package_version",
    "installed_project_runtime_version",
    "installed_project_source_commit",
    "available_pipeline_package_version",
    "available_pipeline_runtime_version",
    "runtime_compatibility",
    "state_declared_next_required_command",
    "state_declared_commands_allowed_now",
    "resolved_commands_allowed_now",
    "stale_state",
    "stale_reasons",
    "routing_decision",
    "routing_reason_codes",
    "phase_result_present",
    "phase_result_structurally_valid",
    "phase_result_contract_hash_valid",
    "audit_result_present",
    "audit_result_structurally_valid",
    "audit_authoritative",
    "audit_evidence_complete",
    "claims_evidence_consistent",
    "flow_restoration_enabled",
    "enforcement_mode",
    "work_item_present",
    "work_item_structurally_valid",
    "work_item_id",
    "goal_epoch",
    "work_item_status",
    "assurance_mode",
    "execution_scope_status",
    "product_execution_allowed",
    "release_actions_allowed",
    "governance_health",
    "owner_interaction_required",
    "product_blocker_count",
    "verification_blocker_count",
    "release_blocker_count",
    "service_warning_count",
    "run_result_present",
    "run_result_structurally_valid",
    "shadow_candidate_command",
    "shadow_candidate_commands_allowed"
  ],
  "properties": {
    "schema_version": {
      "const": "1.1.0"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "pipeline_package_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "runtime_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "project_root": {
      "type": "string",
      "minLength": 1
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1
    },
    "git_root": {
      "type": [
        "string",
        "null"
      ]
    },
    "git_head": {
      "type": [
        "string",
        "null"
      ]
    },
    "state_root": {
      "type": "string",
      "minLength": 1
    },
    "artifact_root": {
      "type": "string",
      "minLength": 1
    },
    "command_inventory_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "command_inventory_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "available_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/[^\\s]+$"
      }
    },
    "current_phase": {
      "type": [
        "string",
        "null"
      ]
    },
    "current_status": {
      "type": "string",
      "enum": [
        "specification_required",
        "planning_required",
        "implementation_ready",
        "implementation_in_progress",
        "awaiting_audit",
        "acceptance_blocked",
        "release_candidate_ready",
        "recovery_required",
        "unknown"
      ]
    },
    "next_required_command": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^/[^\\s]+$"
    },
    "commands_allowed_now": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/[^\\s]+$"
      }
    },
    "routing_valid": {
      "type": "boolean"
    },
    "routing_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "git_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "clean",
        "dirty",
        null
      ]
    },
    "routing_mode": {
      "type": "string",
      "enum": [
        "normal",
        "flow",
        "guarded",
        "release",
        "degraded_product_execution",
        "recovery",
        "invalid"
      ]
    },
    "inventory_source": {
      "type": "string",
      "enum": [
        "project_command_inventory",
        "project_workflow_directory_compat",
        "missing",
        "advisory_only"
      ]
    },
    "inventory_trust": {
      "type": "string",
      "enum": [
        "authoritative",
        "compatibility",
        "none"
      ]
    },
    "inventory_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "inventory_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "inventory_command_count": {
      "type": "integer"
    },
    "installation_manifest_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "installation_manifest_sha256": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-f0-9]{64}$"
    },
    "installed_project_package_version": {
      "type": "string",
      "minLength": 1
    },
    "installed_project_runtime_version": {
      "type": "string",
      "minLength": 1
    },
    "installed_project_source_commit": {
      "type": "string",
      "minLength": 1
    },
    "available_pipeline_package_version": {
      "type": "string",
      "minLength": 1
    },
    "available_pipeline_runtime_version": {
      "type": "string",
      "minLength": 1
    },
    "runtime_compatibility": {
      "type": "string",
      "enum": [
        "compatible",
        "migration_required",
        "unknown"
      ]
    },
    "state_declared_next_required_command": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^/[^\\s]+$"
    },
    "state_declared_commands_allowed_now": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/[^\\s]+$"
      }
    },
    "resolved_commands_allowed_now": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/[^\\s]+$"
      }
    },
    "stale_state": {
      "type": "boolean"
    },
    "stale_reasons": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "evidence",
          "severity"
        ],
        "properties": {
          "code": {
            "type": "string",
            "pattern": "^[A-Z0-9_]+$"
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ]
          }
        }
      }
    },
    "routing_decision": {
      "type": "string",
      "enum": [
        "route",
        "shadow_route",
        "fail_closed",
        "no_executable_route",
        "human_decision_required",
        "reject_unknown_command",
        "already_shipped",
        "work_item_completed",
        "project_archived"
      ]
    },
    "routing_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[A-Z0-9_]+$"
      }
    },
    "phase_result_present": {
      "type": "boolean"
    },
    "phase_result_structurally_valid": {
      "type": "boolean"
    },
    "phase_result_contract_hash_valid": {
      "type": "boolean"
    },
    "audit_result_present": {
      "type": "boolean"
    },
    "audit_result_structurally_valid": {
      "type": "boolean"
    },
    "audit_authoritative": {
      "type": "boolean"
    },
    "audit_evidence_complete": {
      "type": "boolean"
    },
    "claims_evidence_consistent": {
      "type": "boolean"
    },
    "flow_restoration_enabled": {
      "type": "boolean"
    },
    "enforcement_mode": {
      "enum": [
        "shadow",
        "enforcing"
      ]
    },
    "work_item_present": {
      "type": "boolean"
    },
    "work_item_structurally_valid": {
      "type": "boolean"
    },
    "work_item_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "goal_epoch": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "work_item_status": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ready",
        "active",
        "implementation",
        "repair",
        "audit",
        "completed",
        "blocked",
        "archived",
        null
      ]
    },
    "assurance_mode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "flow",
        "guarded",
        "release",
        null
      ]
    },
    "execution_scope_status": {
      "type": "string",
      "enum": [
        "unresolved",
        "exact",
        "blocked"
      ]
    },
    "product_execution_allowed": {
      "type": "boolean"
    },
    "release_actions_allowed": {
      "type": "boolean"
    },
    "governance_health": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded_non_blocking",
        "degraded_blocking",
        "degraded_blocking_release",
        "invalidated_by_external_drift",
        "unknown",
        "invalid"
      ]
    },
    "owner_interaction_required": {
      "type": "boolean"
    },
    "product_blocker_count": {
      "type": "integer",
      "minimum": 0
    },
    "verification_blocker_count": {
      "type": "integer",
      "minimum": 0
    },
    "release_blocker_count": {
      "type": "integer",
      "minimum": 0
    },
    "service_warning_count": {
      "type": "integer",
      "minimum": 0
    },
    "run_result_present": {
      "type": "boolean"
    },
    "run_result_structurally_valid": {
      "type": "boolean"
    },
    "shadow_candidate_command": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^/[^\\s]+$"
    },
    "shadow_candidate_commands_allowed": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^/[^\\s]+$"
      }
    }
  }
}
